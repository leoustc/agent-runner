# /etc/agent-runner/config
#
# One config file can define multiple agent runners.
#
# Multi-agent pattern:
# - agent A:
#     inbox: /srv/agent-a/inbox
# - agent B:
#     inbox: /srv/agent-b/inbox
#
# Each section defines one runner.

[agent-a]
INBOX=/srv/agent-a/inbox
WAITTIME=600
ROLE="Architect"
CLI="/usr/bin/codex exec --yolo"

[agent-b]
INBOX=/srv/agent-b/inbox
WAITTIME=600
ROLE="Backend Engineer"
CLI="/usr/bin/claude --print"

[agent-c]
INBOX=/srv/agent-c/inbox
WAITTIME=600
ROLE="Frontend Engineer"
CLI="/usr/bin/cline"

[agent-d]
INBOX=/srv/agent-d/inbox
WAITTIME=600
ROLE="General Assistant"
CLI="/usr/bin/pi"

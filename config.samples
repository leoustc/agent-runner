# /etc/agent-runner/config
#
# One config file can define multiple agent runners.
#
# Example pattern:
# - master:
#     uses Pi against an Ollama model configured in /root/.pi/agent/models.json
# - architect:
#     uses Codex CLI against the model provider configured in /root/.codex/config.toml
#
# Each section defines one runner.
# TEAM defaults to "default" when omitted.
# WORKSPACE defaults to the parent folder of INBOX when omitted.

[master]
WORKSPACE=/srv/agent-a
INBOX=/srv/agent-a/inbox
WAITTIME=600
ROLE="Manager"
TEAM=default
CLI="/usr/bin/pi --provider ollama --model gemma4 -p @/srv/agent-a/.runner_prompt.md"

[architect]
WORKSPACE=/srv/agent-architect
INBOX=/srv/agent-architect/inbox
WAITTIME=600
ROLE="Architect"
TEAM=default
CLI="/usr/bin/codex --sandbox danger-full-access --ask-for-approval never exec --skip-git-repo-check"
